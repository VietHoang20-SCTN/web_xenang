# === Database ===
DATABASE_URL="mysql://user:password@localhost:3306/xenang"

# === Authentication ===
JWT_SECRET="change-this-secret-before-production"

# === Server ===
PORT=4000

# === CORS (comma-separated) ===
CORS_ORIGINS=http://localhost:5173

# === Cloudinary (for image uploads - persistent storage) ===
# Get your credentials at https://cloudinary.com/console
# You can use either a single URL or individual credentials:
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# CLOUDINARY_CLOUD_NAME="your_cloud_name"
# CLOUDINARY_API_KEY="your_api_key"
# CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_FOLDER="xenang"

# === Frontend (used at build time) ===
VITE_API_URL="http://localhost:4000/api"